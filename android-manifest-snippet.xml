<!-- 
  GOOGLE MOBILE ADS ADMOB INTEGRATION CONFIGURATION
  
  File Location: android/app/src/main/AndroidManifest.xml
  Target Injection Location: Inside the <application> node.
  
  CRITICAL WARNING: Google Mobile Ads SDK requires the 'com.google.android.gms.ads.APPLICATION_ID' 
  metadata tag to be declared. If this is missing or misconfigured, the native app will instantly crash 
